# ==============================================================================
# Root .gitignore for Prime Project Workspace
# ==============================================================================
# This file specifies patterns that Git should ignore across all folders.
# Individual repositories (admin-panel, prime_backend, prime_frontend, prime_mobile)
# have their own .gitignore files, but this root-level ignore serves as a safety net
# and a guide for the whole project.

# ------------------------------------------------------------------------------
# 1. Environment & Sensitive Credentials (NEVER PUSH TO GIT!)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.cert
*.pfx
*.p12
*.jks
keystore
credentials.json
secrets.json

# ------------------------------------------------------------------------------
# 2. Package Managers & Dependency Directories
# ------------------------------------------------------------------------------
node_modules/
bower_components/
jspm_packages/
.npm/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/
.dart_tool/
.pub-cache/
.flutter-plugins
.flutter-plugins-dependencies

# ------------------------------------------------------------------------------
# 3. Build Outputs, Transpiled Code, and Cache
# ------------------------------------------------------------------------------
build/
dist/
out/
.next/
bin/
obj/
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo
/coverage
.eslintcache
.cache/

# ------------------------------------------------------------------------------
# 4. Local Database Files & External Server Binaries
# ------------------------------------------------------------------------------
# Redis dump files and server executables
dump.rdb
*.rdb
redis-server/
# SQLite or local database engines
*.db
*.sqlite
*.sqlite-journal

# ------------------------------------------------------------------------------
# 5. IDEs and Text Editors
# ------------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json

# IntelliJ / Android Studio / WebStorm
.idea/
*.iml
*.ipr
*.iws

# Text Editor Swap Files / Backups
*.swp
*.swo
*~
.history/

# ------------------------------------------------------------------------------
# 6. Operating System Specific Files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini

# ------------------------------------------------------------------------------
# 7. Log Files & Debug Reports
# ------------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------------------------------------------------------
# 8. Temporary & Scratch Folders
# ------------------------------------------------------------------------------
scratch/
temp/
tmp/
uploads/
