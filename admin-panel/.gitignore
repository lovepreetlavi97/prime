# ==============================================================================
# Gitignore for Admin Panel (Next.js Application)
# ==============================================================================

# 1. Environment & Sensitive Credentials (NEVER PUSH TO GIT!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.cert
*.pfx
*.p12

# 2. Package Managers & Dependency Directories
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 3. Next.js and Build Outputs
/.next/
/out/
/build
/dist
/coverage
*.tsbuildinfo
next-env.d.ts
.eslintcache

# 4. IDEs and Text Editors
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.history/

# 5. Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# 6. Log Files & Debug Reports
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 7. Vercel deployment metadata
.vercel
