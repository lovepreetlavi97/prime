# ==============================================================================
# Gitignore for Prime Backend (Node.js Application)
# ==============================================================================

# 1. Environment & Sensitive Credentials (NEVER PUSH TO GIT!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.cert
*.pfx
*.p12
firebase-service-account.json

# 2. Package Managers & Dependency Directories
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 3. Build & Output Folders
/build
/dist
/coverage
*.tsbuildinfo
.eslintcache

# 4. Local Database & External Servers (CRITICAL)
# Redis dump files and server executables/DLLs
dump.rdb
*.rdb
redis-server/
# SQLite or other local engines
*.db
*.sqlite
*.sqlite-journal

# 5. IDEs and Text Editors
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.history/

# 6. Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# 7. Log Files & Debug Reports
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 8. Temporary, Scratch and Uploads Folders
scratch/
temp/
tmp/
/uploads
# Trained data/models (can be downloaded post-deployment)
eng.traineddata
